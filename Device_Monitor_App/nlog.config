<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <targets>
    <!-- 滚动文件日志，按天分割 -->
    <target xsi:type="File"
            name="fileTarget"
            fileName="${basedir}/logs/app-${shortdate}.log"
            layout="${longdate} [${uppercase:${level}}] ${logger} - ${message}${onexception:inner= | ${exception:format=tostring}}"
            archiveEvery="Day"
            maxArchiveFiles="30"
            encoding="utf-8" />

    <!-- 控制台彩色输出（开发调试用） -->
    <target xsi:type="ColoredConsole"
            name="consoleTarget"
            layout="${time} [${uppercase:${level:padding=-5}}] ${logger:shortName=true} - ${message}${onexception:inner= | ${exception:format=message}}" >
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Warn" foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Info" foregroundColor="Green" />
      <highlight-row condition="level == LogLevel.Debug" foregroundColor="Gray" />
    </target>
  </targets>

  <rules>
    <!-- Debug 及以上 → 控制台 -->
    <logger name="*" minlevel="Debug" writeTo="consoleTarget" />
    <!-- Info 及以上 → 文件 -->
    <logger name="*" minlevel="Info" writeTo="fileTarget" />
  </rules>

</nlog>
